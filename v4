# 12.  EXCEL HELPERS  (minimal, clean, professional)
# ══════════════════════════════════════════════════════════════════════════════

_NAVY   = "1F3864"
_BLUE   = "2E75B6"
_TEAL   = "2A6EBB"
_GREEN  = "375623"
_AMBER  = "BF8F00"
_RED    = "C00000"
_WHITE  = "FFFFFF"
_LGREY  = "F5F5F5"
_MGREY  = "D9D9D9"
_LRED   = "FCE4D6"
_LAMBER = "FFF2CC"
_LGREEN = "E2EFDA"
_LBLUE  = "DEEAF1"

def _F(bold=False, color=_WHITE, size=10, italic=False):
    return Font(name="Calibri", bold=bold, color=color, size=size, italic=italic)

def _P(color):
    return PatternFill("solid", fgColor=color)

def _B(style="thin"):
    s = Side(style=style)
    return Border(left=s, right=s, top=s, bottom=s)

def _A(h="left", v="center", wrap=False):
    return Alignment(horizontal=h, vertical=v, wrap_text=wrap)

def _auto_width(ws, mn=8, mx=40):
    for col in ws.columns:
        ltr = get_column_letter(col[0].column)
        w   = max((len(str(c.value or "")) for c in col), default=mn)
        ws.column_dimensions[ltr].width = min(max(w+2, mn), mx)

def _header(ws, headers, row, bg=_NAVY, fg=_WHITE):
    for ci, h in enumerate(headers, 1):
        c = ws.cell(row=row, column=ci, value=h)
        c.font      = _F(bold=True, color=fg, size=10)
        c.fill      = _P(bg)
        c.alignment = _A("center", "center", wrap=True)
        c.border    = _B()
    ws.row_dimensions[row].height = 18

def _rows(ws, df, start, zebra=True):
    for ri, row_data in enumerate(df.itertuples(index=False), start):
        bg = _LGREY if (zebra and (ri-start)%2==0) else _WHITE
        for ci, val in enumerate(row_data, 1):
            if isinstance(val, float) and np.isnan(val): val = ""
            c = ws.cell(row=ri, column=ci, value=val)
            c.fill      = _P(bg)
            c.font      = _F(color="000000")
            c.border    = _B()
            c.alignment = _A("right" if isinstance(val,(int,float)) else "left")

def _section_title(ws, row, col, text, bg=_NAVY):
    c = ws.cell(row=row, column=col, value=text)
    c.font      = _F(bold=True, color=_WHITE, size=10)
    c.fill      = _P(bg)
    c.alignment = _A("left", "center")
    c.border    = _B()


