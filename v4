# 13.  SHEET BUILDERS
# ══════════════════════════════════════════════════════════════════════════════

def _sheet_summary(wb, src, tgt, row_stats, mismatch_df, scorecard_df,
                   key_stats, run_ts, date_col, start_date, end_date):
    ws = wb.create_sheet("Summary")
    ws.sheet_view.showGridLines = False
    ws.column_dimensions["A"].width = 32
    ws.column_dimensions["B"].width = 22
    ws.column_dimensions["C"].width = 22
    ws.column_dimensions["D"].width = 22
    ws.column_dimensions["E"].width = 18

    # ── Banner ──────────────────────────────────────────────────────────────
    ws.merge_cells("A1:E1")
    bc = ws["A1"]
    bc.value     = "DATA QUALITY REPORT  —  Source vs Target"
    bc.font      = Font(name="Calibri", bold=True, color=_WHITE, size=14)
    bc.fill      = _P(_NAVY)
    bc.alignment = _A("center", "center")
    ws.row_dimensions[1].height = 32

    ws.merge_cells("A2:E2")
    sc = ws["A2"]
    period_str = f"  Period: {start_date or 'All'} → {end_date or 'All'}   |   " if date_col else ""
    sc.value     = f"  {period_str}Generated: {run_ts}"
    sc.font      = _F(italic=True, color="404040", size=9)
    sc.fill      = _P(_LBLUE)
    sc.alignment = _A("left", "center")
    ws.row_dimensions[2].height = 15

    # ── Row / Key counts ────────────────────────────────────────────────────
    def _kv_section(ws, start_row, title, pairs, title_bg=_BLUE):
        ws.merge_cells(f"A{start_row}:E{start_row}")
        _section_title(ws, start_row, 1, f"  {title}", bg=title_bg)
        ws.row_dimensions[start_row].height = 16
        for i, (label, src_val, tgt_val, note) in enumerate(pairs, start_row+1):
            bg = _LGREY if i%2==0 else _WHITE
            for ci, val in [(1,label),(2,src_val),(3,tgt_val),(4,note)]:
                c = ws.cell(row=i, column=ci, value=val)
                c.fill = _P(bg); c.font = _F(color="000000")
                c.border = _B(); c.alignment = _A("right" if ci>1 else "left")
            ws.row_dimensions[i].height = 15
        return start_row + 1 + len(pairs)

    # Sub-headers row
    sub_row = 3
    for ci, h in enumerate(["Metric","Source","Target","Note"],1):
        c = ws.cell(row=sub_row, column=ci, value=h)
        c.font = _F(bold=True, color=_WHITE, size=9)
        c.fill = _P(_TEAL); c.border = _B(); c.alignment = _A("center")
    ws.row_dimensions[3].height = 15

    row_pairs = [
        ("Total Rows (original)",   f"{row_stats['source_rows']:,}",  f"{row_stats['target_rows']:,}",  "Before key filter"),
        ("Common Key Rows",         f"{key_stats.get('common_keys','-'):,}" if key_stats else "—", f"{key_stats.get('common_keys','-'):,}" if key_stats else "—", "Used for comparison"),
        ("Keys only in Source",     f"{key_stats.get('only_in_src',0):,}" if key_stats else "—", "—", "Excluded from comparison"),
        ("Keys only in Target",     "—", f"{key_stats.get('only_in_tgt',0):,}" if key_stats else "—", "Excluded from comparison"),
        ("Row Delta",               "—", f"{row_stats['row_delta']:+,}", f"{row_stats['row_delta_pct']:+.2f}%"),
        ("Duplicate Rows",          f"{row_stats['src_duplicates']:,} ({row_stats['src_dup_pct']:.2f}%)",
                                    f"{row_stats['tgt_duplicates']:,} ({row_stats['tgt_dup_pct']:.2f}%)", ""),
        ("Row Hash Match",          f"{row_stats['row_hash_match']:,}", "—", f"{row_stats['row_hash_match_pct']:.2f}% match"),
    ]
    next_row = _kv_section(ws, 4, "ROW & KEY COUNTS", row_pairs, _BLUE)

    # ── Column counts ────────────────────────────────────────────────────────
    common_cols  = len([c for c in src.columns if c in tgt.columns])
    src_only_cols= len([c for c in src.columns if c not in tgt.columns])
    tgt_only_cols= len([c for c in tgt.columns if c not in src.columns])

    col_pairs = [
        ("Source Columns",          f"{len(src.columns):,}", "—", ""),
        ("Target Columns",          "—", f"{len(tgt.columns):,}", ""),
        ("Common Columns",          f"{common_cols:,}", f"{common_cols:,}", "Used for comparison"),
        ("Columns only in Source",  f"{src_only_cols:,}", "—", ""),
        ("Columns only in Target",  "—", f"{tgt_only_cols:,}", ""),
    ]
    next_row += 1
    next_row = _kv_section(ws, next_row, "COLUMN COUNTS", col_pairs, _TEAL)

    # ── Mismatch summary ─────────────────────────────────────────────────────
    if len(mismatch_df):
        total_mm   = int(mismatch_df["Mismatch Count"].sum())
        clean_cols = int((mismatch_df["Mismatch %"]==0).sum())
        high_mm    = int((mismatch_df["Mismatch %"]>=5).sum())
        avg_mm_pct = round(mismatch_df["Mismatch %"].mean(), 2)

        mm_pairs = [
            ("Total Mismatched Cells", f"{total_mm:,}", "—", ""),
            ("Columns — Fully Clean",  f"{clean_cols:,}", "—", "0% mismatch"),
            ("Columns — High Mismatch",f"{high_mm:,}",  "—", "≥5% mismatch"),
            ("Avg Mismatch % (all cols)",f"{avg_mm_pct}%","—", ""),
        ]
        next_row += 1
        next_row = _kv_section(ws, next_row, "CELL-LEVEL MISMATCH COUNTS", mm_pairs, "8B0000")

    # ── Null summary ─────────────────────────────────────────────────────────
    if "SRC Null %" in mismatch_df.columns or "SRC Nulls" in mismatch_df.columns:
        pass  # already in profiling sheet

    # ── Scorecard ─────────────────────────────────────────────────────────────
    next_row += 1
    ws.merge_cells(f"A{next_row}:E{next_row}")
    _section_title(ws, next_row, 1, "  DQ SCORECARD", bg=_NAVY)
    ws.row_dimensions[next_row].height = 16
    next_row += 1
    _header(ws, list(scorecard_df.columns), next_row, bg=_TEAL)
    next_row += 1

    grade_bg = {"A":_LGREEN, "B":_LGREEN, "C":_LAMBER, "D":_LRED, "F":_LRED}
    for ri, row_data in enumerate(scorecard_df.itertuples(index=False), next_row):
        is_overall = "OVERALL" in str(row_data[0])
        grade_char = str(row_data[3])[0] if len(str(row_data[3]))>0 else "A"
        bg = _LAMBER if is_overall else grade_bg.get(grade_char, _WHITE)
        for ci, val in enumerate(row_data, 1):
            if isinstance(val, float) and np.isnan(val): val = ""
            c = ws.cell(row=ri, column=ci, value=val)
            c.fill = _P(bg)
            c.font = Font(name="Calibri", bold=is_overall, color="000000" if not is_overall else _NAVY, size=10)
            c.border = _B()
            c.alignment = _A("right" if ci==2 else "left")
        ws.row_dimensions[ri].height = 15


def _sheet_schema(wb, schema_df):
    ws = wb.create_sheet("Schema Comparison")
    ws.sheet_view.showGridLines = False
    ws.merge_cells("A1:F1")
    c = ws["A1"]
    c.value = "Schema Comparison"; c.font = _F(bold=True, color=_WHITE, size=11)
    c.fill = _P(_NAVY); c.alignment = _A("left","center")
    ws.row_dimensions[1].height = 22

    _header(ws, list(schema_df.columns), 2, bg=_BLUE)
    _rows(ws, schema_df, 3)

    status_ci = list(schema_df.columns).index("Status") + 1
    for ri in range(3, 3+len(schema_df)):
        val = str(ws.cell(row=ri, column=status_ci).value or "")
        if "Missing" in val:
            for ci in range(1,7): ws.cell(row=ri, column=ci).fill = _P(_LRED)
        elif "Type Mismatch" in val:
            for ci in range(1,7): ws.cell(row=ri, column=ci).fill = _P(_LAMBER)
        else:
            ws.cell(row=ri, column=status_ci).fill = _P(_LGREEN)
    _auto_width(ws)


def _sheet_profiling(wb, profile_df):
    ws = wb.create_sheet("Column Profiling")
    ws.sheet_view.showGridLines = False
    ws.merge_cells("A1:D1")
    c = ws["A1"]
    c.value = "Column-Level Profiling  (Source vs Target)"; c.font = _F(bold=True,color=_WHITE,size=11)
    c.fill = _P(_NAVY); c.alignment = _A("left","center")
    ws.row_dimensions[1].height = 22

    _header(ws, list(profile_df.columns), 2, bg=_TEAL)
    _rows(ws, profile_df, 3)

    null_ci = next((i+1 for i,h in enumerate(profile_df.columns) if h=="SRC Null %"), None)
    if null_ci:
        for ri in range(3, 3+len(profile_df)):
            try:
                v = float(ws.cell(row=ri, column=null_ci).value or 0)
                if v>20:   ws.cell(row=ri, column=null_ci).fill = _P(_LRED)
                elif v>5:  ws.cell(row=ri, column=null_ci).fill = _P(_LAMBER)
            except Exception: pass

    ws.freeze_panes = "C3"
    _auto_width(ws)


def _sheet_mismatch_summary(wb, mismatch_df):
    ws = wb.create_sheet("Mismatch Summary")
    ws.sheet_view.showGridLines = False
    ws.merge_cells("A1:G1")
    c = ws["A1"]
    c.value = "Cell-Level Mismatch Summary  (per column)"; c.font = _F(bold=True,color=_WHITE,size=11)
    c.fill = _P(_NAVY); c.alignment = _A("left","center")
    ws.row_dimensions[1].height = 22

    _header(ws, list(mismatch_df.columns), 2, bg=_BLUE)
    _rows(ws, mismatch_df, 3)

    mm_ci = list(mismatch_df.columns).index("Mismatch %") + 1
    ml    = get_column_letter(mm_ci)
    lr    = 2 + len(mismatch_df)
    ws.conditional_formatting.add(f"{ml}3:{ml}{lr}", ColorScaleRule(
        start_type="num", start_value=0,   start_color="E2EFDA",
        mid_type="num",   mid_value=5,     mid_color="FFF2CC",
        end_type="num",   end_value=100,   end_color="FCE4D6",
    ))
    ws.freeze_panes = "B3"
    _auto_width(ws)


def _sheet_mismatch_samples(wb, samples_df):
    ws = wb.create_sheet("Mismatch Samples")
    ws.sheet_view.showGridLines = False
    ws.merge_cells("A1:E1")
    c = ws["A1"]
    c.value = "Mismatch Samples  (row-level examples)"; c.font = _F(bold=True,color=_WHITE,size=11)
    c.fill = _P(_NAVY); c.alignment = _A("left","center")
    ws.row_dimensions[1].height = 22

    if not len(samples_df):
        ws.cell(row=3,column=1,value="No mismatches found — datasets are identical.").font = _F(bold=True,color="375623",size=11)
        return

    _header(ws, list(samples_df.columns), 2, bg=_BLUE)
    _rows(ws, samples_df, 3)

    mt_ci = list(samples_df.columns).index("Mismatch Type") + 1
    for ri in range(3, 3+len(samples_df)):
        v = str(ws.cell(row=ri, column=mt_ci).value or "")
        if "Value Mismatch" in v:
            ws.cell(row=ri, column=3).fill = _P(_LRED)
            ws.cell(row=ri, column=4).fill = _P(_LRED)
        elif "Null" in v:
            ws.cell(row=ri, column=3).fill = _P(_LAMBER)
            ws.cell(row=ri, column=4).fill = _P(_LAMBER)
    _auto_width(ws)


def _sheet_time(wb, time_results):
    ws = wb.create_sheet("Time Analysis")
    ws.sheet_view.showGridLines = False
    if not time_results:
        ws.cell(row=1,column=1,value="No date column detected — time analysis not available.")
        return

    cur = 1
    for label, df in time_results.items():
        if df is None or not len(df): continue
        ws.merge_cells(start_row=cur, start_column=1, end_row=cur, end_column=min(len(df.columns),15))
        _section_title(ws, cur, 1, f"  {label} Aggregation", bg=_NAVY)
        ws.row_dimensions[cur].height = 18
        cur += 1

        cols = [c for c in df.columns if not df[c].isna().all()][:15]
        disp = df[cols].copy()
        if "Period" in disp.columns:
            disp["Period"] = disp["Period"].astype(str)

        _header(ws, list(disp.columns), cur, bg=_BLUE)
        cur += 1
        _rows(ws, disp, cur)
        cur += len(disp) + 3

    _auto_width(ws)


def _sheet_row_checks(wb, row_stats, key_stats):
    ws = wb.create_sheet("Row & Duplicate Checks")
    ws.sheet_view.showGridLines = False
    ws.merge_cells("A1:D1")
    c = ws["A1"]
    c.value = "Row-Level & Duplicate Analysis"; c.font = _F(bold=True,color=_WHITE,size=11)
    c.fill = _P(_NAVY); c.alignment = _A("left","center")
    ws.row_dimensions[1].height = 22

    data = [
        ("Metric","Source","Target","Note"),
        ("Total Rows",f"{row_stats['source_rows']:,}",f"{row_stats['target_rows']:,}",f"Delta: {row_stats['row_delta']:+,}"),
        ("Duplicate Rows",f"{row_stats['src_duplicates']:,}",f"{row_stats['tgt_duplicates']:,}",
         f"SRC {row_stats['src_dup_pct']:.2f}% | TGT {row_stats['tgt_dup_pct']:.2f}%"),
        ("Row Hash Match",f"{row_stats['row_hash_match']:,}",f"{row_stats['row_hash_mismatch']:,} mismatches",
         f"{row_stats['row_hash_match_pct']:.2f}% match"),
    ]
    if key_stats:
        data += [
            ("Common Keys",    f"{key_stats.get('common_keys',0):,}", f"{key_stats.get('common_keys',0):,}", "Used for comparison"),
            ("Keys only in SRC",f"{key_stats.get('only_in_src',0):,}", "—", "Excluded"),
            ("Keys only in TGT","—", f"{key_stats.get('only_in_tgt',0):,}", "Excluded"),
        ]

    for ri, row in enumerate(data, 2):
        bg = _NAVY if ri==2 else (_LGREY if ri%2==0 else _WHITE)
        fg = _WHITE if ri==2 else "000000"
        for ci, val in enumerate(row, 1):
            c = ws.cell(row=ri, column=ci, value=val)
            c.font = Font(name="Calibri", bold=(ri==2), color=fg, size=10)
            c.fill = _P(bg); c.border = _B()
            c.alignment = _A("center" if ci>1 else "left", "center")
        ws.row_dimensions[ri].height = 15

    # Sample missing keys
    for lbl, key in [("Keys in Source but NOT in Target:", "sample_src_only"),
                     ("Keys in Target but NOT in Source:", "sample_tgt_only")]:
        vals = key_stats.get(key, []) if key_stats else []
        if vals:
            r = ws.max_row + 2
            ws.cell(row=r,column=1,value=lbl).font = Font(name="Calibri",bold=True,color="000000",size=10)
            for i, k in enumerate(vals, r+1):
                ws.cell(row=i,column=1,value=str(k)).font = _F(color="000000")

    ws.column_dimensions["A"].width = 35
    ws.column_dimensions["B"].width = 22
    ws.column_dimensions["C"].width = 22
    ws.column_dimensions["D"].width = 30


def _sheet_advanced(wb, adv_df):
    ws = wb.create_sheet("Advanced DQ")
    ws.sheet_view.showGridLines = False
    ws.merge_cells("A1:M1")
    c = ws["A1"]
    c.value = "Advanced DQ — Distribution Drift & Outlier Detection"; c.font = _F(bold=True,color=_WHITE,size=11)
    c.fill = _P(_NAVY); c.alignment = _A("left","center")
    ws.row_dimensions[1].height = 22

    if not len(adv_df):
        ws.cell(row=3,column=1,value="No numeric columns available for advanced checks."); return

    _header(ws, list(adv_df.columns), 2, bg=_TEAL)
    _rows(ws, adv_df, 3)

    drift_ci = list(adv_df.columns).index("Distribution Drift") + 1
    for ri in range(3, 3+len(adv_df)):
        if "Drift" in str(ws.cell(row=ri, column=drift_ci).value or ""):
            for ci in range(1, len(adv_df.columns)+1):
                ws.cell(row=ri,column=ci).fill = _P(_LAMBER)
    _auto_width(ws)


def _sheet_scorecard(wb, scorecard_df):
    ws = wb.create_sheet("DQ Scorecard")
    ws.sheet_view.showGridLines = False
    ws.merge_cells("A1:E1")
    c = ws["A1"]
    c.value = "DQ Scorecard"; c.font = Font(name="Calibri",bold=True,color=_WHITE,size=14)
    c.fill = _P(_NAVY); c.alignment = _A("center","center")
    ws.row_dimensions[1].height = 32

    _header(ws, list(scorecard_df.columns), 3, bg=_BLUE)
    grade_bg = {"A":_LGREEN,"B":_LGREEN,"C":_LAMBER,"D":_LRED,"F":_LRED}
    for ri, row_data in enumerate(scorecard_df.itertuples(index=False), 4):
        is_overall = "OVERALL" in str(row_data[0])
        grade_char = str(row_data[3])[0]
        bg = _LAMBER if is_overall else grade_bg.get(grade_char, _WHITE)
        for ci, val in enumerate(row_data, 1):
            if isinstance(val, float) and np.isnan(val): val = ""
            c = ws.cell(row=ri, column=ci, value=val)
            c.fill = _P(bg)
            c.font = Font(name="Calibri", bold=is_overall, color="000000", size=10)
            c.border = _B()
            c.alignment = _A("right" if ci==2 else "left","center")
        ws.row_dimensions[ri].height = 18

    _auto_width(ws)
    ws.column_dimensions["E"].width = 40


