# ══════════════════════════════════════════════════════════════════════════════
# 1.  DATA LOADING  (call once, keep in memory)
# ══════════════════════════════════════════════════════════════════════════════

def load_csv(filepath: str, chunksize: int = 500_000) -> pd.DataFrame:
    """
    Robust CSV loader — strips null bytes, auto-detects delimiter, chunked.
    Call this ONCE per file and keep the result in a variable.
    """
    log.info(f"Loading  {filepath}")
    with open(filepath, "rb") as fh:
        raw = fh.read()
    cleaned = raw.replace(b"\x00", b"").replace(b"\r\n", b"\n")
    buf     = io.StringIO(cleaned.decode("utf-8", errors="replace"))

    sample = buf.read(4096); buf.seek(0)
    delim  = next((d for d in [",", "|", "\t", ";"] if d in sample), ",")

    NULL_VALS = {"", "NULL", "null", "None", "none", "NA", "N/A", "NaN", "nan", "#N/A"}
    chunks = []
    for chunk in pd.read_csv(buf, sep=delim, chunksize=chunksize,
                             low_memory=False, on_bad_lines="warn",
                             na_values=NULL_VALS, keep_default_na=True,
                             quotechar='"', escapechar="\\"):
        chunks.append(chunk)
        gc.collect()

    df = pd.concat(chunks, ignore_index=True)
    log.info(f"  → {len(df):,} rows  ×  {len(df.columns)} cols")
    return df


# ══════════════════════════════════════════════════════════════════════════════
# 2.  TYPE DETECTION & COERCION
# ══════════════════════════════════════════════════════════════════════════════

_DATE_HINTS = [r"\d{4}-\d{2}-\d{2}", r"\d{2}/\d{2}/\d{4}", r"\d{2}-\d{2}-\d{4}"]

def _detect_types(df: pd.DataFrame) -> dict:
    result = {}
    for col in df.columns:
        s = df[col].dropna().head(500)
        if pd.api.types.is_numeric_dtype(df[col]):
            result[col] = "numeric"; continue
        if pd.api.types.is_datetime64_any_dtype(df[col]):
            result[col] = "date"; continue
        ss = s.astype(str)
        if any(ss.str.match(p).mean() > 0.8 for p in _DATE_HINTS):
            result[col] = "date"; continue
        try:
            pd.to_numeric(s, errors="raise")
            result[col] = "numeric"
        except Exception:
            try:
                n_unique = df[col].nunique()
                result[col] = "categorical" if n_unique / max(len(df[col].dropna()), 1) < 0.5 else "text"
            except Exception:
                result[col] = "text"
    return result

def _coerce(df: pd.DataFrame, col_types: dict) -> pd.DataFrame:
    df = df.copy()
    for col, ctype in col_types.items():
        if col not in df.columns: continue
        try:
            if ctype == "numeric":
                df[col] = pd.to_numeric(df[col], errors="coerce")
            elif ctype == "date":
                df[col] = pd.to_datetime(df[col], errors="coerce")
        except Exception:
            pass  # leave column as-is if coercion fails
    return df


# ══════════════════════════════════════════════════════════════════════════════
# 3.  DATE FILTERING  (non-destructive — works on a copy)
# ══════════════════════════════════════════════════════════════════════════════

def _apply_date_filter(
    df: pd.DataFrame,
    date_col: Optional[str],
    start_date: Optional[str],
    end_date: Optional[str],
) -> pd.DataFrame:
    if not date_col or date_col not in df.columns:
        return df
    if not start_date and not end_date:
        return df
    s = pd.to_datetime(df[date_col], errors="coerce")
    mask = pd.Series(True, index=df.index)
    if start_date:
        mask &= s >= pd.Timestamp(start_date)
    if end_date:
        mask &= s <= pd.Timestamp(end_date)
    filtered = df[mask].reset_index(drop=True)
    log.info(f"  Date filter [{start_date} → {end_date}]: {len(df):,} → {len(filtered):,} rows")
    return filtered


# ══════════════════════════════════════════════════════════════════════════════
# 4.  COMMON KEY FILTERING  (only IDs present in BOTH datasets)
# ══════════════════════════════════════════════════════════════════════════════

def _filter_common_keys(
    src: pd.DataFrame,
    tgt: pd.DataFrame,
    key_col: str,
) -> tuple[pd.DataFrame, pd.DataFrame, dict]:
    src_keys = set(src[key_col].dropna().astype(str))
    tgt_keys = set(tgt[key_col].dropna().astype(str))
    common   = src_keys & tgt_keys

    src_only = src_keys - tgt_keys
    tgt_only = tgt_keys - src_keys

    src_f = src[src[key_col].astype(str).isin(common)].copy()
    tgt_f = tgt[tgt[key_col].astype(str).isin(common)].copy()

    # cast key to str before sort so int vs str never clash
    src_f[key_col] = src_f[key_col].astype(str)
    tgt_f[key_col] = tgt_f[key_col].astype(str)
    src_f = src_f.sort_values(key_col).reset_index(drop=True)
    tgt_f = tgt_f.sort_values(key_col).reset_index(drop=True)

    key_stats = {
        "total_src_keys"  : len(src_keys),
        "total_tgt_keys"  : len(tgt_keys),
        "common_keys"     : len(common),
        "only_in_src"     : len(src_only),
        "only_in_tgt"     : len(tgt_only),
        "sample_src_only" : sorted(src_only, key=str)[:20],
        "sample_tgt_only" : sorted(tgt_only, key=str)[:20],
    }
    log.info(f"  Common keys: {len(common):,}  |  Src-only: {len(src_only):,}  |  Tgt-only: {len(tgt_only):,}")
    return src_f, tgt_f, key_stats


