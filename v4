# 5.  SCHEMA COMPARISON
# ══════════════════════════════════════════════════════════════════════════════

def _compare_schemas(src: pd.DataFrame, tgt: pd.DataFrame) -> pd.DataFrame:
    sc = {c: str(src[c].dtype) for c in src.columns}
    tc = {c: str(tgt[c].dtype) for c in tgt.columns}
    rows = []
    for col in sorted(set(sc) | set(tc)):
        in_s, in_t = col in sc, col in tc
        st, tt = sc.get(col, "—"), tc.get(col, "—")
        status = (
            "Both Present"      if in_s and in_t and st == tt else
            "Type Mismatch"     if in_s and in_t else
            "Missing in Source" if not in_s else
            "Missing in Target"
        )
        rows.append({
            "Column"          : col,
            "Status"          : status,
            "Source Dtype"    : st,
            "Target Dtype"    : tt,
            "Source Position" : list(src.columns).index(col)+1 if in_s else None,
            "Target Position" : list(tgt.columns).index(col)+1 if in_t else None,
        })
    return pd.DataFrame(rows)


# ══════════════════════════════════════════════════════════════════════════════
# 6.  COLUMN PROFILING
# ══════════════════════════════════════════════════════════════════════════════

def _profile_col(series: pd.Series, ctype: str, label: str) -> dict:
    n       = len(series)
    nulls   = int(series.isna().sum())
    nn      = series.dropna()
    distinct= int(series.nunique(dropna=True))

    d = {
        f"{label} Rows"       : n,
        f"{label} Nulls"      : nulls,
        f"{label} Null %"     : round(nulls/n*100, 2) if n else 0,
        f"{label} Non-Null"   : len(nn),
        f"{label} Distinct"   : distinct,
        f"{label} Duplicates" : max(len(nn)-distinct, 0),
        f"{label} Fill Rate %" : round(len(nn)/n*100, 2) if n else 0,
    }

    if ctype == "numeric" and len(nn):
        # force numeric — column may have been str after key-col cast
        nn_num = pd.to_numeric(nn, errors="coerce").dropna()
        if len(nn_num):
            try:
                d.update({
                    f"{label} Min"    : round(float(nn_num.min()),         4),
                    f"{label} Max"    : round(float(nn_num.max()),         4),
                    f"{label} Mean"   : round(float(nn_num.mean()),        4),
                    f"{label} Median" : round(float(nn_num.median()),      4),
                    f"{label} StdDev" : round(float(nn_num.std()),         4),
                    f"{label} Q1"     : round(float(nn_num.quantile(.25)), 4),
                    f"{label} Q3"     : round(float(nn_num.quantile(.75)), 4),
                })
            except Exception:
                pass
    elif ctype == "date" and len(nn):
        try:
            nn_dt = pd.to_datetime(nn, errors="coerce").dropna()
            if len(nn_dt):
                d.update({
                    f"{label} Min Date"  : str(nn_dt.min()),
                    f"{label} Max Date"  : str(nn_dt.max()),
                    f"{label} Date Range": (nn_dt.max()-nn_dt.min()).days if len(nn_dt)>1 else 0,
                })
        except Exception:
            pass
    return d

def _profile_all(src, tgt, ct_src, ct_tgt) -> pd.DataFrame:
    common = [c for c in src.columns if c in tgt.columns]
    rows = []
    for col in common:
        ctype = ct_src.get(col, "text")
        row = {"Column": col, "Type": ctype}
        row.update(_profile_col(src[col], ctype, "SRC"))
        row.update(_profile_col(tgt[col], ct_tgt.get(col, ctype), "TGT"))
        if ctype == "numeric":
            sm = row.get("SRC Mean"); tm = row.get("TGT Mean")
            if sm is not None and tm is not None and sm != 0:
                row["Mean Δ"]   = round(tm - sm, 4)
                row["Mean Δ %"] = round((tm-sm)/abs(sm)*100, 2)
        row["Fill Δ %"] = round(
            row.get("TGT Fill Rate %", 0) - row.get("SRC Fill Rate %", 0), 2
        )
        rows.append(row)
    return pd.DataFrame(rows)


# ══════════════════════════════════════════════════════════════════════════════
# 7.  CELL-LEVEL COMPARISON
# ══════════════════════════════════════════════════════════════════════════════

def _classify_mm(sv, tv) -> str:
    if pd.isna(sv) and pd.isna(tv): return "Both Null"
    if pd.isna(sv):  return "Null in Source"
    if pd.isna(tv):  return "Null in Target"
    if str(sv).strip().lower() == str(tv).strip().lower(): return "Case/Space Diff"
    try:
        if abs(float(sv)-float(tv)) < 1e-9: return "Float Precision"
    except Exception: pass
    return "Value Mismatch"

def _cell_compare(src, tgt, sample_n=50):
    common  = [c for c in src.columns if c in tgt.columns]
    n_rows  = min(len(src), len(tgt))
    s_cmp   = src[common].iloc[:n_rows].reset_index(drop=True)
    t_cmp   = tgt[common].iloc[:n_rows].reset_index(drop=True)

    summary, samples = [], []
    for col in common:
        sv = s_cmp[col].astype(str).str.strip()
        tv = t_cmp[col].astype(str).str.strip()
        mm = sv != tv
        mc = int(mm.sum())
        mp = round(mc/n_rows*100, 4) if n_rows else 0
        summary.append({
            "Column"         : col,
            "Rows Compared"  : n_rows,
            "Match Count"    : n_rows - mc,
            "Match %"        : round(100-mp, 4),
            "Mismatch Count" : mc,
            "Mismatch %"     : mp,
            "Status"         : "Clean" if mp==0 else "Minor (<5%)" if mp<5 else "High Mismatch",
        })
        if mc and len(samples) < sample_n * 5:
            for i in mm[mm].index[:sample_n]:
                samples.append({
                    "Row Index"     : int(i),
                    "Column"        : col,
                    "Source Value"  : s_cmp[col].iloc[i],
                    "Target Value"  : t_cmp[col].iloc[i],
                    "Mismatch Type" : _classify_mm(s_cmp[col].iloc[i], t_cmp[col].iloc[i]),
                })
    return pd.DataFrame(summary), pd.DataFrame(samples)


# ══════════════════════════════════════════════════════════════════════════════
# 8.  ROW-LEVEL CHECKS
# ══════════════════════════════════════════════════════════════════════════════

def _row_checks(src, tgt, key_stats: Optional[dict] = None) -> dict:
    r = {
        "source_rows"     : len(src),
        "target_rows"     : len(tgt),
        "row_delta"       : len(tgt)-len(src),
        "row_delta_pct"   : round((len(tgt)-len(src))/max(len(src),1)*100, 4),
        "src_duplicates"  : int(src.duplicated().sum()),
        "tgt_duplicates"  : int(tgt.duplicated().sum()),
    }
    r["src_dup_pct"] = round(r["src_duplicates"]/max(len(src),1)*100, 4)
    r["tgt_dup_pct"] = round(r["tgt_duplicates"]/max(len(tgt),1)*100, 4)

    n    = min(len(src), len(tgt))
    common_cols = [c for c in src.columns if c in tgt.columns]
    sh   = pd.util.hash_pandas_object(src[common_cols].iloc[:n], index=False)
    th   = pd.util.hash_pandas_object(tgt[common_cols].iloc[:n], index=False)
    matches = int((sh.values == th.values).sum())
    r["row_hash_match"]    = matches
    r["row_hash_mismatch"] = n - matches
    r["row_hash_match_pct"]= round(matches/n*100, 4) if n else 0

    if key_stats:
        r.update(key_stats)
    return r


# ══════════════════════════════════════════════════════════════════════════════
# 9.  TIME-BASED ANALYSIS
# ══════════════════════════════════════════════════════════════════════════════

def _time_analysis(src, tgt, ct_src, ct_tgt, date_col=None) -> dict:
    if not date_col:
        # auto-detect
        candidates = [c for c,t in ct_src.items() if t=="date" and c in tgt.columns]
        if not candidates: return {}
        for hint in ["date","dt","mth","month","period"]:
            for c in candidates:
                if hint in c.lower(): date_col = c; break
            if date_col: break
        if not date_col: date_col = candidates[0]

    num_cols = [c for c,t in ct_src.items() if t=="numeric" and c in tgt.columns][:15]
    if not num_cols: return {}

    use = [date_col] + num_cols
    s2  = src[use].copy(); t2 = tgt[use].copy()
    s2[date_col] = pd.to_datetime(s2[date_col], errors="coerce")
    t2[date_col] = pd.to_datetime(t2[date_col], errors="coerce")
    s2 = s2.dropna(subset=[date_col]); t2 = t2.dropna(subset=[date_col])

    result = {}
    for freq, label, fmt in [
        ("ME","Monthly","%Y-%m"), ("QE","Quarterly",""), ("YE","Yearly","%Y")
    ]:
        as_ = s2.set_index(date_col).resample(freq)[num_cols].agg(["sum","count","nunique"])
        at_ = t2.set_index(date_col).resample(freq)[num_cols].agg(["sum","count","nunique"])
        as_.columns = [f"SRC_{c}_{a}" for c,a in as_.columns]
        at_.columns = [f"TGT_{c}_{a}" for c,a in at_.columns]
        merged = as_.join(at_, how="outer").reset_index()
        merged.rename(columns={date_col:"Period"}, inplace=True)
        if freq == "QE":
            merged["Period"] = merged["Period"].dt.to_period("Q").astype(str)
        else:
            merged["Period"] = merged["Period"].dt.strftime(fmt)
        result[label] = merged

    # 3-month rolling on first numeric col sum
    if "Monthly" in result and num_cols:
        m = result["Monthly"]
        for pfx in ["SRC","TGT"]:
            sc = f"{pfx}_{num_cols[0]}_sum"
            if sc in m.columns:
                m[f"{pfx}_3M_Rolling"] = m[sc].rolling(3, min_periods=1).mean().round(2)
        result["Monthly"] = m
    return result


# ══════════════════════════════════════════════════════════════════════════════
# 10.  ADVANCED DQ — KS DRIFT + OUTLIERS
# ══════════════════════════════════════════════════════════════════════════════

def _advanced_dq(src, tgt, ct_src) -> pd.DataFrame:
    rows = []
    for col, ctype in ct_src.items():
        if ctype != "numeric" or col not in tgt.columns: continue
        sv = pd.to_numeric(src[col], errors="coerce").dropna()
        tv = pd.to_numeric(tgt[col], errors="coerce").dropna()
        if len(sv)<10 or len(tv)<10: continue

        def iqr_out(s):
            q1,q3 = s.quantile(.25), s.quantile(.75)
            iqr   = q3-q1
            return int(((s<q1-1.5*iqr)|(s>q3+1.5*iqr)).sum())
        def z_out(s):
            return int((np.abs(scipy_stats.zscore(s))>3).sum())

        ks, ksp = scipy_stats.ks_2samp(sv.values, tv.values)
        rows.append({
            "Column"              : col,
            "KS Statistic"        : round(ks, 4),
            "KS p-value"          : round(ksp, 4),
            "Distribution Drift"  : "Drift Detected" if ksp<0.05 else "Stable",
            "SRC IQR Outliers"    : iqr_out(sv),
            "TGT IQR Outliers"    : iqr_out(tv),
            "SRC Z-Score Outliers": z_out(sv),
            "TGT Z-Score Outliers": z_out(tv),
            "SRC Min"             : round(float(sv.min()),4),
            "SRC Max"             : round(float(sv.max()),4),
            "TGT Min"             : round(float(tv.min()),4),
            "TGT Max"             : round(float(tv.max()),4),
        })
    return pd.DataFrame(rows)


# ══════════════════════════════════════════════════════════════════════════════
# 11.  DQ SCORECARD
# ══════════════════════════════════════════════════════════════════════════════

def _scorecard(profile_df, mismatch_df, row_stats, schema_df) -> pd.DataFrame:
    completeness = profile_df["SRC Fill Rate %"].mean() if "SRC Fill Rate %" in profile_df else 100.0
    consistency  = (schema_df["Status"]=="Both Present").sum() / max(len(schema_df),1) * 100
    accuracy     = 100 - mismatch_df["Mismatch %"].mean() if len(mismatch_df) else 100.0
    validity     = 100 - row_stats.get("src_dup_pct", 0)
    overall      = round(0.35*completeness + 0.25*consistency + 0.30*accuracy + 0.10*validity, 2)

    def grade(s):
        return "A — Excellent" if s>=95 else "B — Good" if s>=85 else "C — Acceptable" if s>=70 else "D — Poor" if s>=50 else "F — Critical"

    return pd.DataFrame([
        {"Dimension":"Completeness", "Score":round(completeness,2), "Weight":"35%", "Grade":grade(completeness), "Description":"Avg fill-rate across source columns"},
        {"Dimension":"Consistency",  "Score":round(consistency,2),  "Weight":"25%", "Grade":grade(consistency),  "Description":"Schema / dtype alignment"},
        {"Dimension":"Accuracy",     "Score":round(accuracy,2),     "Weight":"30%", "Grade":grade(accuracy),     "Description":"Cell-level value match"},
        {"Dimension":"Validity",     "Score":round(validity,2),     "Weight":"10%", "Grade":grade(validity),     "Description":"Duplicate-free rows"},
        {"Dimension":"OVERALL",      "Score":overall,               "Weight":"100%","Grade":grade(overall),      "Description":"Weighted composite"},
    ])


