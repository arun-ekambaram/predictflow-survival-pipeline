# 14.  MAIN ENTRY POINT  —  call with pre-loaded DataFrames
# ══════════════════════════════════════════════════════════════════════════════

def run_dq_report(
    src              : pd.DataFrame,
    tgt              : pd.DataFrame,
    key_col          : Optional[str] = None,
    date_col         : Optional[str] = None,
    start_date       : Optional[str] = None,   # "YYYY-MM-DD"
    end_date         : Optional[str] = None,   # "YYYY-MM-DD"
    output_path      : str           = "DQ_Report.xlsx",
    sample_mismatches: int           = 50,
) -> str:
    """
    Generate a full DQ Excel report from pre-loaded DataFrames.

    Parameters
    ----------
    src               : Source DataFrame (load once via load_csv())
    tgt               : Target DataFrame (load once via load_csv())
    key_col           : Primary key column for key-based filtering & comparison
    date_col          : Date column name for time filtering & time analysis
    start_date        : Filter start date  "YYYY-MM-DD"  (inclusive)
    end_date          : Filter end date    "YYYY-MM-DD"  (inclusive)
    output_path       : Output file name
    sample_mismatches : Max mismatch sample rows per column

    Returns
    -------
    str  : path to generated Excel file
    """
    run_ts = datetime.now().strftime("%Y-%m-%d %H:%M:%S")
    log.info("=" * 60)
    log.info("  DQ FRAMEWORK — Starting Run")
    log.info(f"  SRC: {len(src):,} rows  |  TGT: {len(tgt):,} rows")
    if date_col:
        log.info(f"  Date col: {date_col}  |  Range: {start_date or 'All'} → {end_date or 'All'}")
    log.info("=" * 60)

    # ── Step 1: Date filter (non-destructive, works on copies) ──────────────
    log.info("[1/9] Applying date filter …")
    s = _apply_date_filter(src, date_col, start_date, end_date)
    t = _apply_date_filter(tgt, date_col, start_date, end_date)

    # ── Step 2: Detect types & coerce ───────────────────────────────────────
    log.info("[2/9] Detecting column types …")
    ct_src = _detect_types(s)
    ct_tgt = _detect_types(t)
    s = _coerce(s, ct_src)
    t = _coerce(t, ct_tgt)

    # ── Step 3: Common key filtering ────────────────────────────────────────
    key_stats = None
    if key_col and key_col in s.columns and key_col in t.columns:
        log.info(f"[3/9] Filtering to common keys on '{key_col}' …")
        s, t, key_stats = _filter_common_keys(s, t, key_col)
    else:
        log.info("[3/9] No key column — using full row comparison …")

    # ── Step 4: Schema ───────────────────────────────────────────────────────
    log.info("[4/9] Schema comparison …")
    schema_df = _compare_schemas(s, t)

    # ── Step 5: Column profiling ─────────────────────────────────────────────
    log.info("[5/9] Column profiling …")
    profile_df = _profile_all(s, t, ct_src, ct_tgt)

    # ── Step 6: Cell-level comparison ────────────────────────────────────────
    log.info("[6/9] Cell-level comparison …")
    mismatch_df, samples_df = _cell_compare(s, t, sample_n=sample_mismatches)

    # ── Step 7: Row checks ───────────────────────────────────────────────────
    log.info("[7/9] Row-level checks …")
    row_stats = _row_checks(s, t, key_stats)

    # ── Step 8: Time analysis ─────────────────────────────────────────────────
    log.info("[8/9] Time-based analysis …")
    time_results = _time_analysis(s, t, ct_src, ct_tgt, date_col=date_col)

    # ── Step 9: Advanced DQ ──────────────────────────────────────────────────
    log.info("[9/9] Advanced DQ (drift + outliers) …")
    adv_df = _advanced_dq(s, t, ct_src)

    # ── Scorecard ─────────────────────────────────────────────────────────────
    scorecard_df = _scorecard(profile_df, mismatch_df, row_stats, schema_df)

    # ── Build Excel ───────────────────────────────────────────────────────────
    log.info("Building Excel report …")
    wb = Workbook()
    wb.remove(wb.active)

    _sheet_summary        (wb, s, t, row_stats, mismatch_df, scorecard_df,
                           key_stats, run_ts, date_col, start_date, end_date)
    _sheet_schema         (wb, schema_df)
    _sheet_profiling      (wb, profile_df)
    _sheet_mismatch_summary(wb, mismatch_df)
    _sheet_mismatch_samples(wb, samples_df)
    _sheet_time           (wb, time_results)
    _sheet_row_checks     (wb, row_stats, key_stats)
    _sheet_advanced       (wb, adv_df)
    _sheet_scorecard      (wb, scorecard_df)

    wb.save(output_path)
    log.info(f"Report saved  →  {output_path}")
    log.info("=" * 60)
    return output_path
